# ══════════════════════════════════════════════════════════════════════════════
# OPTION A: Anthropic — Claude 4.x (recommended)
#
# Node-to-model affinity (Haiku-preferred for cost):
#
#   analyze_topic    → reasoning_llm → Sonnet 4.6  ($3/$15 per 1M)
#   validate_quality → reasoning_llm → Sonnet 4.6  (critical scoring — needs reliability)
#   plan_research    → code_llm      → Haiku 4.5   ($1/$5  per 1M)
#   generate_questions→ code_llm     → Haiku 4.5   (bulk generation — cheapest first)
#   synthesize_context→ balanced_llm → Haiku 4.5   (prose summary — Haiku's sweet spot)
#
#   Fallback cascade on rate limit:
#     reasoning_llm: Sonnet → Haiku → Opus
#     code_llm:      Haiku  → Sonnet       (Opus excluded — overkill for these tasks)
#     balanced_llm:  Haiku  → Sonnet
# ══════════════════════════════════════════════════════════════════════════════
LLM_API_KEY=sk-ant-...                             # https://console.anthropic.com
LLM_PROVIDER=anthropic
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_USE_ROUTER=true

# Router model slots  (primary = reasoning tier, secondary = routine tier, fallback = safety net)
ROUTER_PRIMARY_MODEL=claude-sonnet-4-6             # reasoning nodes — Sonnet 4.6
ROUTER_SECONDARY_MODEL=claude-haiku-4-5-20251001   # routine nodes  — Haiku 4.5  ← preferred
ROUTER_FALLBACK_MODEL=claude-opus-4-7              # last resort    — Opus 4.7 (rarely activates)

# ══════════════════════════════════════════════════════════════════════════════
# OPTION B: OpenRouter — free tier (original)
# ══════════════════════════════════════════════════════════════════════════════
# LLM_API_KEY=sk-or-v1-...
# LLM_PROVIDER=openrouter
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=8192
# LLM_USE_ROUTER=true
# ROUTER_PRIMARY_MODEL=deepseek/deepseek-v4-flash:free    # reasoning (1M ctx, score=77)
# ROUTER_SECONDARY_MODEL=qwen/qwen3-coder:free            # code/generation (1M ctx)
# ROUTER_FALLBACK_MODEL=google/gemma-4-31b-it:free        # balanced (256K ctx, dense)

# ══════════════════════════════════════════════════════════════════════════════
# Single-model mode (bypass router — use --model flag or set LLM_USE_ROUTER=false)
# ══════════════════════════════════════════════════════════════════════════════
# LLM_USE_ROUTER=false
# LLM_MODEL=claude-sonnet-4-6    # only used when use_router=false or --model is set

# ── Research ──────────────────────────────────────────────────────────────────
RESEARCH_SEARCH_PROVIDER=tavily              # "tavily" | "duckduckgo" | "wikipedia"
RESEARCH_TAVILY_API_KEY=tvly-...             # required only when provider=tavily
RESEARCH_MAX_RESULTS_PER_QUERY=5
RESEARCH_MAX_RESEARCH_QUERIES=3
RESEARCH_TAVILY_SEARCH_DEPTH=advanced        # "basic" | "advanced"
RESEARCH_TAVILY_INCLUDE_RAW_CONTENT=true
RESEARCH_TAVILY_INCLUDE_ANSWER=true

# ── Dataset generation ────────────────────────────────────────────────────────
DATASET_DEFAULT_NUM_QUESTIONS=20
DATASET_MAX_RETRIES=3
DATASET_QUALITY_THRESHOLD=0.75
DATASET_OUTPUT_FORMAT=json                   # "json" | "jsonl" | "csv"
DATASET_OUTPUT_DIR=./output
DATASET_GENERATION_BATCH_SIZE=5              # questions per LLM call — keep low to avoid truncation

# ── Observability (optional) ──────────────────────────────────────────────────
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=dataset-agent
